# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored — secrets never get committed.
#
# Only these 4 features need keys. Everything else works with no keys at all.
# Leave any blank and that single feature simply hides; the rest of the app is unaffected.

# --- Free power-stack (recommended) ---
# Groq — preferred LLM: fast, free, Llama-3.3-70B. Powers summaries, content
# plans, and drafts. Get a free key at console.groq.com. If set, used instead of HF.
GROQ_API_KEY=

# Brave Search — real competitor discovery + SERP signal (free 2,000/mo).
# Get a free key at api-dashboard.search.brave.com
BRAVE_API_KEY=

# Upstash Redis — free persistent cache that survives Render restarts.
# Create a free DB at console.upstash.com and copy the REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Feature 23 — AI summary fallback (Hugging Face). Optional if GROQ_API_KEY is set.
HUGGINGFACE_API_TOKEN=

# Feature 11 — news article count (GNews, 100 req/day free)
GNEWS_API_KEY=

# Feature 12 — YouTube video count (optional; skip if you didn't make a key)
YOUTUBE_API_KEY=

# Feature 13 — GitHub repository count
GITHUB_TOKEN=

# Demo mode (optional). When set to 1, the tool falls back to clearly-labelled
# synthetic "Sample data" if Google Trends is unavailable (rate-limited / blocked),
# so a live client demo never shows empty cards. Off by default. Real data always
# wins when available; demo data is always flagged "Sample data" in the UI.
TRENDPULSE_DEMO=0

# CORS — the frontend origin allowed to call this API.
# In local dev this is the Vite dev server. In prod, your Vercel URL.
# Comma-separated for multiple. Defaults to "*" if blank.
FRONTEND_ORIGIN=http://localhost:5173
